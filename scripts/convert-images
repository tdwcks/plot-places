#!/bin/bash
#
# Convert JPG/PNG images to WebP for Plot places.
#
# Expects: images/<city>/<place-name>/photo.jpg
# Outputs: images/<place-name>-1.webp, <place-name>-2.webp, etc.
#
# Usage:
#   ./scripts/convert-images                # convert all
#   ./scripts/convert-images tate-modern    # convert only one place
#
# Requires: cwebp (brew install webp)

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
IMAGES_DIR="$REPO_DIR/images"
QUALITY=100
MAX_WIDTH=1200

if ! command -v cwebp &> /dev/null; then
    echo "Error: cwebp not found. Install with: brew install webp"
    exit 1
fi

filter="${1:-}"
converted=0
skipped=0

shopt -s nullglob nocaseglob

for place_dir in "$IMAGES_DIR"/*/*/; do
    [ -d "$place_dir" ] || continue

    place_name="$(basename "$place_dir")"

    # Filter by name if argument provided
    if [ -n "$filter" ] && [[ "$place_name" != *"$filter"* ]]; then
        continue
    fi

    # Collect source images
    sources=()
    for file in "$place_dir"*.jpg "$place_dir"*.jpeg "$place_dir"*.png; do
        sources+=("$file")
    done

    if [ ${#sources[@]} -eq 0 ]; then
        continue
    fi

    echo "$place_name (${#sources[@]} images):"

    index=1
    for file in "${sources[@]}"; do
        webp_file="$IMAGES_DIR/$place_name-$index.webp"

        if [ -f "$webp_file" ]; then
            echo "  skip: $place_name-$index.webp (exists)"
            skipped=$((skipped + 1))
        else
            echo "  convert: $(basename "$file") → $place_name-$index.webp"
            cwebp -q "$QUALITY" -resize "$MAX_WIDTH" 0 "$file" -o "$webp_file" -quiet
            converted=$((converted + 1))
        fi

        index=$((index + 1))
    done
done

shopt -u nullglob nocaseglob

if [ $converted -eq 0 ] && [ $skipped -eq 0 ]; then
    echo "No images found. Expected: images/<city>/<place-name>/*.jpg"
else
    echo ""
    echo "Converted: $converted, Skipped: $skipped"
fi
